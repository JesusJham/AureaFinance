# ============================================
# AUREA FINANCE API - Variables de Entorno
# ============================================

# Información de la aplicación
APP_NAME="Aurea Finance API"
DEBUG=false
SECRET_KEY=cambia-esta-clave-segura-en-produccion-minimo-32-caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# CORS - URLs permitidas (separadas por comas)
# Para producción en Vercel: https://tu-dominio-vercel.vercel.app
ALLOWED_ORIGINS=["http://localhost:5500","https://tu-dominio.com","https://project-wk0hp.vercel.app"]


# ============================================
# BASE DE DATOS - NEON POSTGRESQL
# ============================================
# Formato: postgresql://usuario:password@host:puerto/nombre_bd?sslmode=require
# Este valor viene de tu dashboard de Neon
# NO compartir públicamente, usar variables secretas en Render
DATABASE_URL=postgresql://neondb_owner:npg_XXXXX@ep-bold-mode-XXXXX.sa-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ============================================
# CONFIGURACIÓN DE PUERTO (para Render)
# ============================================
# Render asigna automáticamente el puerto en PORT
# Déjalo en 0.0.0.0 para aceptar conexiones externas
PORT=8000
HOST=0.0.0.0
