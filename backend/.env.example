# Copia este archivo como .env y completa los valores reales
APP_NAME="Aurea Finance API"
DEBUG=false
SECRET_KEY=cambia-esta-clave-segura-en-produccion
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["http://localhost:5500","https://tu-dominio.com"]

# SQLite (desarrollo)
DATABASE_URL=sqlite:///./aurea.db

# PostgreSQL (producción) — descomenta y ajusta
